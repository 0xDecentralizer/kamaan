<div class="kashi-divider" aria-hidden="true"></div>

<!-- Contact Section -->
<section class="section" id="contact" aria-label="تماس با ما">
  <h2 class="section-title">تماس با ما</h2>
  <p class="section-sub">پیشنهادات و بازخوردهای خود را با ما به اشتراک بگذارید</p>
  <div class="contact-grid">
    <form class="contact-form" name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" action="/contact/success">
      <input type="hidden" name="form-name" value="contact">
      <p class="sr-only">
        <label>Don't fill this out: <input name="bot-field"></label>
      </p>
      <div class="form-group">
        <label class="form-label" for="name">نام</label>
        <input class="form-input" type="text" id="name" name="name" placeholder="نام خود را وارد کنید" required autocomplete="name">
      </div>
      <div class="form-group">
        <label class="form-label" for="email">ایمیل</label>
        <input class="form-input" type="email" id="email" name="email" placeholder="example@email.com" required autocomplete="email">
      </div>
      <div class="form-group">
        <label class="form-label" for="subject">موضوع</label>
        <input class="form-input" type="text" id="subject" name="subject" placeholder="موضوع پیام">
      </div>
      <div class="form-group">
        <label class="form-label" for="message">پیام</label>
        <textarea class="form-textarea" id="message" name="message" placeholder="پیام خود را بنویسید..." required></textarea>
      </div>
      <button type="submit" class="btn-primary" style="width: 100%; justify-content: center;">
        ارسال پیام
      </button>
    </form>
    <div class="contact-info">
      <div class="contact-info-card">
        <h3>کانال تلگرام</h3>
        <p>برای دریافت جدیدترین موسیقی‌ها و مطالب فرهنگی، در کانال تلگرام ما عضو شوید.</p>
        <a href="{{ site.telegramUrl }}" target="_blank" rel="noopener">عضویت در کانال</a>
      </div>
      <div class="contact-info-card">
        <h3>ایمیل</h3>
        <p>برای همکاری، پیشنهادات و انتقادات با ما در تماس باشید.</p>
        <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      </div>
      <div class="contact-info-card">
        <h3>شبکه‌های اجتماعی</h3>
        <p>ما را در شبکه‌های اجتماعی دنبال کنید و از آخرین اخبار مطلع شوید.</p>
        <a href="{{ site.telegramUrl }}" target="_blank" rel="noopener">تلگرام</a>
      </div>
    </div>
  </div>
</section>

<!-- Audio Element (hidden) -->
<audio id="audioPlayer" preload="metadata"></audio>

<script>
(function() {
  'use strict';
  
  // Track data from Eleventy
  const tracks = {{ music.tracks | json | safe }};
  let currentTrack = 0;
  let isPlaying = false;
  
  const audio = document.getElementById('audioPlayer');
  const playBtn = document.getElementById('playBtn');
  const playIcon = document.getElementById('playIcon');
  const progressBar = document.getElementById('progressBar');
  const currentTimeEl = document.getElementById('currentTime');
  const totalTimeEl = document.getElementById('totalTime');
  const volumeSlider = document.getElementById('volumeSlider');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const rewindBtn = document.getElementById('rewindBtn');
  const forwardBtn = document.getElementById('forwardBtn');
  
  // Format time in Persian
  function formatTime(seconds) {
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    const persianDigits = ['۰', '۱', '۲', '۳', '۴', '۵', '۶', '۷', '۸', '۹'];
    const toPersian = (n) => String(n).replace(/\d/g, d => persianDigits[d]);
    return toPersian(mins) + ':' + toPersian(secs.toString().padStart(2, '0'));
  }
  
  function updatePlayPauseUI() {
    playIcon.innerHTML = isPlaying
      ? '<rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/>'
      : '<polygon points="5 3 19 12 5 21 5 3"/>';
    playBtn.setAttribute('aria-label', isPlaying ? 'توقف' : 'پخش');
  }
  
  function selectTrack(index) {
    if (index < 0 || index >= tracks.length) return;
    currentTrack = index;
    const track = tracks[currentTrack];
    
    // Update UI
    document.getElementById('nowPlayingTitle').textContent = track.title;
    document.getElementById('nowPlayingArtist').textContent = track.artist;
    document.getElementById('nowPlayingDastgah').textContent = track.dastgah + ' — ' + track.instrument;
    totalTimeEl.textContent = track.duration;
    currentTimeEl.textContent = '۰:۰۰';
    progressBar.style.width = '0%';
    
    // Update active track
    document.querySelectorAll('.playlist-item').forEach((item, i) => {
      item.classList.toggle('active', i === currentTrack);
    });
    
    // Load audio if URL exists
    if (track.url) {
      audio.src = track.url;
      audio.load();
    }
    
    document.querySelector('.player-title') && 
      document.querySelector('.player-title').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
  
  // Play/Pause
  playBtn.addEventListener('click', () => {
    const track = tracks[currentTrack];
    if (!track.url) {
      // Show visual feedback only
      isPlaying = !isPlaying;
      updatePlayPauseUI();
      return;
    }
    
    if (isPlaying) {
      audio.pause();
    } else {
      audio.play().catch(() => {});
    }
    isPlaying = !isPlaying;
    updatePlayPauseUI();
  });
  
  // Previous/Next
  prevBtn.addEventListener('click', () => selectTrack(currentTrack - 1));
  nextBtn.addEventListener('click', () => selectTrack(currentTrack + 1));
  
  // Rewind/Forward 10 seconds
  rewindBtn.addEventListener('click', () => {
    if (audio.src) audio.currentTime = Math.max(0, audio.currentTime - 10);
  });
  forwardBtn.addEventListener('click', () => {
    if (audio.src) audio.currentTime = Math.min(audio.duration || 0, audio.currentTime + 10);
  });
  
  // Volume
  if (volumeSlider) {
    volumeSlider.addEventListener('input', (e) => {
      audio.volume = e.target.value / 100;
    });
    audio.volume = 0.8;
  }
  
  // Audio time update
  audio.addEventListener('timeupdate', () => {
    if (audio.duration) {
      const progress = (audio.currentTime / audio.duration) * 100;
      progressBar.style.width = progress + '%';
      currentTimeEl.textContent = formatTime(audio.currentTime);
      totalTimeEl.textContent = formatTime(audio.duration);
    }
  });
  
  audio.addEventListener('ended', () => {
    if (currentTrack < tracks.length - 1) {
      selectTrack(currentTrack + 1);
      audio.play().catch(() => {});
    } else {
      isPlaying = false;
      updatePlayPauseUI();
    }
  });
  
  // Playlist click
  document.querySelectorAll('.playlist-item').forEach((item) => {
    item.addEventListener('click', () => {
      const index = parseInt(item.dataset.index);
      selectTrack(index);
      if (tracks[index].url) {
        audio.play().catch(() => {});
        isPlaying = true;
        updatePlayPauseUI();
      }
    });
    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        item.click();
      }
    });
  });
  
  // Progress bar click (seek)
  const progressContainer = document.getElementById('progressContainer');
  if (progressContainer) {
    progressContainer.addEventListener('click', (e) => {
      if (audio.src && audio.duration) {
        const rect = progressContainer.getBoundingClientRect();
        const clickX = e.clientX - rect.left;
        const percent = clickX / rect.width;
        audio.currentTime = percent * audio.duration;
      }
    });
  }
  
  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
    if (e.key === ' ' && document.activeElement === playBtn) {
      e.preventDefault();
      playBtn.click();
    }
  });
  
  // Initialize
  selectTrack(0);
})();
</script>