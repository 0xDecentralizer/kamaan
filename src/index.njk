      <div class="instrument-icon">
        <svg viewBox="0 0 80 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <g stroke="#3b82f6" stroke-width="1.5">
            <path d="M20 90c0-11 9-20 20-20s20 9 20 20" fill="none"/>
            <circle cx="40" cy="92" r="10" fill="none" stroke-width="1" opacity="0.5"/>
            <line x1="40" y1="70" x2="40" y2="20" stroke-width="2"/>
            <circle cx="40" cy="16" r="3" fill="none"/>
            <path d="M28 88c0-6.6 5.4-12 12-12s12 5.4 12 12" fill="none" stroke-width="1" opacity="0.4"/>
            <circle cx="40" cy="92" r="3" fill="#3b82f6" opacity="0.2"/>
          </g>
        </svg>
      </div>
      <h3 class="instrument-name">تار</h3>
      <p class="instrument-desc">ساز زهی با شش سیم، نماد موسیقی ایرانی</p>
