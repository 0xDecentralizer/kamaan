</section>

<div class="kashi-divider" aria-hidden="true"></div>

<!-- Blog Section -->
<section class="section" id="blog" aria-label="مقالات">
  <h2 class="section-title">مقالات و مطالب فرهنگی</h2>
  <p class="section-sub">از تاریخ و فرهنگ ایران‌زمین بخوانید</p>
