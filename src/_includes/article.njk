---
layout: base.njk
---

<!-- Breadcrumb -->
<nav class="breadcrumb" aria-label="مسیر صفحه">
  <ol>
    <li><a href="/">خانه</a></li>
    <li><a href="/articles/">مقالات</a></li>
    <li aria-current="page">{{ title }}</li>
  </ol>
</nav>

<article class="section" style="max-width: 800px;" itemscope itemtype="https://schema.org/Article">
  <meta itemprop="headline" content="{{ title }}">
  <meta itemprop="description" content="{{ description or excerpt }}">
  <meta itemprop="datePublished" content="{{ page.date | dateISO }}">

  <a href="/articles/" class="article-back-link">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
    بازگشت به مقالات
  </a>

  <span class="blog-card-tag" style="position: static; display: inline-block; margin-bottom: 16px;">{{ category }}</span>
  
  <h1 itemprop="headline" class="article-title">{{ title }}</h1>
  
  <div class="article-meta">
    <time itemprop="datePublished" datetime="{{ page.date | dateISO }}" class="article-meta-date">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      {{ page.date | dateFormat }}
    </time>
    <span class="article-meta-sep">•</span>
    <span class="article-meta-reading" id="readingTime">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      در حال محاسبه...
    </span>
    {% if tags %}
    <span class="article-meta-sep">•</span>
    <div class="article-tags">
      {% for tag in tags %}
      <span class="article-tag">{{ tag }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </div>

  <div class="article-content" itemprop="articleBody">
    {{ content | safe }}
  </div>

  <!-- Share -->
  <div class="article-share">
    <span class="article-share-label">اشتراک‌گذاری:</span>
    <a href="https://t.me/share/url?url={{ site.url }}{{ page.url }}&text={{ title }}" 
       target="_blank" rel="noopener" 
       class="article-share-btn"
       aria-label="اشتراک در تلگرام">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
    </a>
    <button class="article-share-btn" 
            onclick="navigator.clipboard.writeText(window.location.href).then(() => this.classList.add('copied'))" 
            aria-label="کپی لینک"
            title="کپی لینک">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
    </button>
  </div>

  <!-- Related Articles -->
  <div class="related-articles">
    <h2 class="related-title">مقالات مرتبط</h2>
    <div class="related-grid" id="relatedGrid">
      <!-- Populated by JS -->
    </div>
  </div>
</article>

<style>
  .article-title {
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.4;
    color: var(--fg);
  }
  .article-content {
    font-size: 16px;
    line-height: 2;
    color: var(--fg-secondary);
    text-align: justify;
  }
  .article-content h2 {
    font-size: 22px;
    font-weight: 700;
    margin: 32px 0 16px;
    color: var(--fg);
    text-align: right;
  }
  .article-content h3 {
    font-size: 18px;
    font-weight: 600;
    margin: 24px 0 12px;
    color: var(--fg);
  }
  .article-content p {
    margin-bottom: 16px;
  }
  .article-content ul, .article-content ol {
    margin: 16px 0;
    padding-right: 24px;
  }
  .article-content li {
    margin-bottom: 8px;
  }
  .article-content blockquote {
    border-right: 3px solid var(--accent);
    padding: 20px 24px;
    margin: 24px 0;
    background: var(--surface);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-style: italic;
    color: var(--fg);
    font-size: 17px;
    line-height: 2;
  }
  .article-content strong {
    font-weight: 600;
    color: var(--fg);
  }
  .article-back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
    margin-bottom: 32px;
    transition: color 0.2s;
  }
  .article-back-link:hover {
    color: var(--accent);
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
    flex-wrap: wrap;
    color: var(--muted);
    font-size: 14px;
  }
  .article-meta-date, .article-meta-reading {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .article-meta-sep {
    opacity: 0.4;
  }
  .article-tags {
    display: flex;
    gap: 6px;
  }
  .article-tag {
    background: var(--primary-light);
    color: var(--primary);
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
  }

  /* Share */
  .article-share {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .article-share-label {
    font-size: 14px;
    color: var(--muted);
    font-weight: 500;
  }
  .article-share-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--fg-secondary);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
  }
  .article-share-btn:hover {
    background: var(--primary-light);
    border-color: var(--primary);
    color: var(--primary);
    transform: translateY(-2px);
  }
  .article-share-btn.copied {
    background: var(--accent-light);
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Related */
  .related-articles {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .related-title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 24px;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }
  .related-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }
  .related-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-clay);
    border-color: var(--primary);
  }
  .related-card-cat {
    font-size: 12px;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 8px;
  }
  .related-card-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: 4px;
  }
  .related-card-date {
    font-size: 12px;
    color: var(--muted);
  }
</style>

<script>
(function() {
  'use strict';
  
  // Calculate reading time
  const content = document.querySelector('.article-content');
  const readingTimeEl = document.getElementById('readingTime');
  if (content && readingTimeEl) {
    const text = content.textContent || content.innerText;
    const words = text.trim().split(/\s+/).length;
    const minutes = Math.ceil(words / 200);
    readingTimeEl.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> ' + minutes + ' دقیقه مطالعه';
  }
  
  // Related articles (show random articles from same category, excluding current)
  const currentUrl = window.location.pathname;
  const currentCategory = '{{ category }}';
  const allArticles = [
    {% for article in collections.articles %}
    {
      url: '{{ article.url }}',
      title: '{{ article.data.title }}',
      category: '{{ article.data.category }}',
      date: '{{ article.date | dateFormat }}',
      excerpt: '{{ article.data.excerpt }}'
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ];
  
  const related = allArticles
    .filter(a => a.url !== currentUrl)
    .sort((a, b) => a.category === currentCategory && b.category !== currentCategory ? -1 : 1)
    .slice(0, 3);
  
  const grid = document.getElementById('relatedGrid');
  if (grid && related.length > 0) {
    grid.innerHTML = related.map(a => `
      <a href="${a.url}" class="related-card">
        <div class="related-card-cat">${a.category}</div>
        <div class="related-card-title">${a.title}</div>
        <div class="related-card-date">${a.date}</div>
      </a>
    `).join('');
  }
})();
</script>